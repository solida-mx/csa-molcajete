// MOLCAJETE · Configuración del Worker (Cloudflare)
// Pega aquí el ID real de tu namespace KV donde dice PEGA-AQUI-EL-ID.
// Ver INSTRUCCIONES-DISPONIBILIDAD.txt, paso 2.
{
  "name": "csa-molcajete",
  "main": "worker.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "DISPO",
      "id": "PEGA-AQUI-EL-ID"
    }
  ]
}
